APP_NAME=ReaDirect
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL is the ReaDirect target database for Phase 4+.
# SQLite can still be used for quick local experiments by setting
# DB_CONNECTION=sqlite and DB_DATABASE=database/database.sqlite in a private .env.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=readirect
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=120
OPENAI_TEMPERATURE=0.4

STT_PROVIDER=mock
STT_TIMEOUT_SECONDS=30
STT_SAMPLE_RATE_HZ=16000
STT_LANGUAGE=en
STT_MOCK_TRANSCRIPT=
STT_FFMPEG_PATH=ffmpeg
STT_CONVERT_TO_WAV=false

# ReaDirect-AI-ASR FastAPI Wav2Vec2-only service.
# Run separately from the ReaDirect-AI-ASR repo:
# uvicorn api.main:app --reload --host 127.0.0.1 --port 8001
READIRECT_AI_ENABLED=true
AI_ASR_SERVICE_URL=http://127.0.0.1:8001
READIRECT_AI_BASE_URL=http://127.0.0.1:8001
READIRECT_AI_API_TOKEN=
READIRECT_AI_TIMEOUT_SECONDS=60
READIRECT_AI_HEALTH_ENDPOINT=/health
READIRECT_AI_VERSION_ENDPOINT=/version
READIRECT_AI_ANALYZE_AUDIO_ENDPOINT=/analyze-audio
READIRECT_AI_ANALYZE_TEXT_ENDPOINT=/analyze-text
READIRECT_AI_RECOMMEND_NEXT_ENDPOINT=/recommend-next
READIRECT_AI_CONTENT_ITEM_ENDPOINT=/content-item
READIRECT_AI_FALLBACK_TO_STT=true
READIRECT_AI_USE_MANUAL_TRANSCRIPT=true
READIRECT_AI_ADMIN_DEBUG=false
ENABLE_ASR_DEBUG_METADATA=false
USE_CORRECTED_TRANSCRIPT_FOR_SCORING=true
USE_DISPLAYED_TRANSCRIPT_FOR_LEARNER_UI=true
ASR_ARCHITECTURE=wav2vec2_only
ASR_MODEL_NAME=epsilon
ASR_MODEL_PATH=C:\Users\Lost\Documents\holder-ReaDirect\ReaDirect-AI-ASR\models\asr\epsilon
ASR_DECODE_MODE=beam_lm
ASR_BEAM_WIDTH=100
ASR_LM_PATH=C:\Users\Lost\Documents\holder-ReaDirect\ReaDirect-AI-ASR\external_datasets\language_models\3-gram.pruned.1e-7.arpa
ASR_ALPHA=0.5
ASR_BETA=1.0
ASR_HOTWORDS=
ASR_HOTWORD_WEIGHT=5.0
ASR_ALLOW_NO_LM_FALLBACK=false

# Developer QA / sandbox controls. Defaults are production-safe when unset.
READIRECT_DEVELOPER_QA_MODE=false
READIRECT_ASSESSMENT_DEBUG=false
READIRECT_LEARNER_MANUAL_FALLBACK=false
READIRECT_QA_ALLOW_JUMP_CONTROLS=false
READIRECT_QA_ALLOW_FLOW_BYPASS=false
READIRECT_QA_AUTO_TRANSCRIBE_ON_STOP=false
READIRECT_QA_SHOW_AI_DEBUG=false
READIRECT_QA_FORCE_LEARNER_STAGE=false
READIRECT_QA_RESET_LEARNER_FLOW=false

REA_CIEL_SPEC_PATH=../ReaDirect-IA
CIEL_AGENT_ENABLED=true
CIEL_AGENT_BASE_URL=http://127.0.0.1:8003
CIEL_AGENT_DECIDE_ENDPOINT=/ia/ciel/decide
CIEL_AGENT_STATUS_ENDPOINT=/ia/ciel/status
CIEL_AGENT_CONNECT_TIMEOUT_SECONDS=1
CIEL_AGENT_TIMEOUT_SECONDS=3
IA_GRAPHICS_PATH=

# Local Kokoro TTS is optional. Browser speech and text remain fallbacks.
TTS_ENABLED=false
TTS_PROVIDER=kokoro
TTS_BASE_URL=http://127.0.0.1:8002
TTS_TIMEOUT_SECONDS=10
TTS_FALLBACK_TO_TEXT=true
TTS_CACHE_ENABLED=true
TTS_CACHE_BYPASS=false
TTS_ENGINE=kokoro
TTS_EXPRESSIVE_ENGINE_ENABLED=true
TTS_EXPRESSIVE_ENGINE=index_tts2
TTS_EXPRESSIVE_FALLBACK_TO_KOKORO=false
INDEXTTS2_ENABLED=true
INDEXTTS2_ADAPTER_MODULE=index_tts2_adapter
INDEXTTS2_REPO_PATH=external/index-tts
INDEXTTS2_MODEL_DIR=external/index-tts/checkpoints
INDEXTTS2_CONFIG_PATH=external/index-tts/checkpoints/config.yaml
INDEXTTS2_DEVICE=auto
INDEXTTS2_OUTPUT_SAMPLE_RATE=24000
TTS_REFERENCE_MANIFEST_PATH=storage/tts/references/manifest.json
TTS_REFERENCE_AUDIO_ROOT=storage/tts/references
TTS_EMOTION_PROMPT_INTRO="warm, friendly, welcoming, gentle"
TTS_EMOTION_PROMPT_GENTLE_REASSURANCE="gentle, warm, reassuring"
TTS_EMOTION_PROMPT_FRIENDLY_ENCOURAGEMENT="cheerful and encouraging"
TTS_EMOTION_PROMPT_HAPPY_PRAISE="bright, pleased, supportive praise"
TTS_EMOTION_PROMPT_FOCUSED_INSTRUCTION="focused, clear, patient instruction"
TTS_EMOTION_PROMPT_CALM_EVALUATION="calm and supportive"
TTS_EMOTION_PROMPT_PLAYFUL_FRIEND="light, friendly, playful reading buddy"
TTS_CACHE_ROOT=storage/tts/cache
TTS_COMPARISON_OUTPUT_ROOT=storage/tts/cache/comparisons
TTS_DEBUG_LOGGING=true
TTS_AGENT_PROFILES_ENABLED=true
TTS_AGENT_SPEED_VIVIAN=0.97
TTS_AGENT_SPEED_CIEL=0.94
TTS_AGENT_SPEED_ESTELLE=0.93
TTS_AUTO_PROMPT_EXTENSION_ENABLED=false
TTS_CURATED_PROMPTS_ENABLED=true
TTS_CURATED_PROMPT_TARGET_SECONDS=7.0
TTS_CURATED_PROMPT_MIN_SECONDS=6.0
TTS_CURATED_PROMPT_MAX_SECONDS=9.0
TTS_REFERENCE_WEIGHTING_ENABLED=true
TTS_REFERENCE_HIGH_PRIORITY_MIN_SECONDS=7.0
TTS_REFERENCE_MEDIUM_PRIORITY_MIN_SECONDS=4.0
READIRECT_TTS_TWO_STAGE_GENERATION=true
READIRECT_TTS_STAGE1_REFERENCE_STYLE_ENABLED=true
READIRECT_TTS_STAGE2_KOKORO_IDENTITY_ENABLED=true
READIRECT_TTS_ACTIVE_STAGE=reference_style
READIRECT_TTS_DEFENSE_AUDIO_TYPE=reference_style
READIRECT_TTS_STAGE2_DEMO_AUDIO_TYPE=kokoro_identity
READIRECT_TTS_ALLOW_STAGE_SWITCH=true
READIRECT_TTS_FALLBACK_TO_OTHER_STAGE=false
READIRECT_TTS_FALLBACK_TO_RUNTIME_TTS=false
READIRECT_TTS_FALLBACK_TO_RAW_KOKORO=false
READIRECT_VOICE_DATABASE_MODE=true
READIRECT_VOICE_DATABASE_STRICT=false
READIRECT_VOICE_LINE_CYCLING_ENABLED=true
READIRECT_VOICE_LINE_RANDOM_SELECTION_ENABLED=false
READIRECT_TTS_GENERATED_PUBLIC_ROOT=tts/generated_voice_lines
TTS_TEXT_HUMANIZER_ENABLED=true
TTS_TEXT_HUMANIZER_MODE=friendly
TTS_TEXT_HUMANIZER_VARIATION_ENABLED=true
TTS_TEXT_HUMANIZER_LOGGING=true
TTS_DELIVERY_CONTROL_ENABLED=true
TTS_SAFE_CHUNKING_ENABLED=true
TTS_MIN_FRIENDLY_TOKENS=12
TTS_MAX_COACHING_SENTENCES=3
TTS_HUMANIZER_ENABLED=true
TTS_AUDIO_NORMALIZE_ENABLED=true
TTS_AUDIO_FADE_ENABLED=true
TTS_PAUSE_CONTROL_ENABLED=true
TTS_BREATHS_ENABLED=false
TTS_BREATHS_VOLUME=0.08
TTS_BREATHS_MIN_TEXT_LENGTH=80

# Local admin setup reference. These values are not committed secrets.
# Use them with: php artisan readirect:create-admin admin@readirect.local --name="ReaDirect Admin" --password="ChangeThisPassword123!"
SEED_ADMIN_NAME="ReaDirect Admin"
SEED_ADMIN_EMAIL=admin@readirect.local
SEED_ADMIN_PASSWORD=ChangeThisPassword123!

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@readirect.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_REA_AGENT_ASSET_BASE_URL=/ia-assets
